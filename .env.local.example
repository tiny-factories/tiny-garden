# Are.na OAuth
ARENA_CLIENT_ID=
ARENA_CLIENT_SECRET=
ARENA_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=localhost:3000

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
# Snapshot (full payload) — billing logic in /api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Thin destination signing secret (if Stripe requires a second endpoint) — /api/billing/webhook-thin
STRIPE_WEBHOOK_THIN_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# One-time Price ID (beta Supporter / $300 lifetime) — create as "One time" in Stripe Dashboard
STRIPE_SUPPORTER_PRICE_ID=

# Analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Cron (Vercel auto-sets this, or generate with: openssl rand -hex 32)
CRON_SECRET=

# Databases
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
BLOB_READ_WRITE_TOKEN