# Are.na OAuth
ARENA_CLIENT_ID=
ARENA_CLIENT_SECRET=
ARENA_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Optional: personal access token for the account that owns /templates preview channels (admin → Template examples).
# If unset, the oldest admin user's OAuth token is used (dev only is fine).
# ARENA_EXAMPLE_TOKEN=

# App
# Include scheme (https:// or http://). Stripe checkout rejects bare hostnames.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=localhost:3000

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=
# Optional: share session between apex and www (leading dot), e.g. .tiny.garden
# SESSION_COOKIE_DOMAIN=

# Stripe
STRIPE_SECRET_KEY=
# Snapshot (full payload) — billing logic in /api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Thin destination signing secret (if Stripe requires a second endpoint) — /api/billing/webhook-thin
STRIPE_WEBHOOK_THIN_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# One-time Price ID: price_… (legacy checkout when no valid monthly amount is sent)
# Monthly amounts from the pricing slider use Checkout subscription mode + price_data (no extra Price IDs).
STRIPE_SUPPORTER_PRICE_ID=

# Buttondown waitlist — newsletter slug from Settings → Embedding (same as in the form action URL),
# e.g. TinyFactories for https://buttondown.com/api/emails/embed-subscribe/TinyFactories
# Used by POST /api/waitlist (server proxy; tags signups with tiny-garden — create that tag in Buttondown if needed).
NEXT_PUBLIC_BUTTONDOWN_USER=

# Analytics (Umami v3)
# Website ID from your Umami site settings (UUID).
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Full URL to script.js — self-hosted v3: https://your-umami.example.com/script.js
# Server webhooks use the same host + /api/send (see src/lib/umami-server.ts).
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Cron (Vercel auto-sets this, or generate with: openssl rand -hex 32)
CRON_SECRET=

# Vercel API (for custom domain management)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Databases
# App runtime: Neon "Pooled" / pooler URL is fine.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Prisma Migrate: optional on Vercel/Neon if DATABASE_URL uses a *-pooler.* host — we derive the direct URL. Set explicitly for non-standard poolers or to override.
# DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Force-skip migrate during `yarn build` / Vercel build (overrides everything).
# PRISMA_SKIP_MIGRATE_DEPLOY=1
# Vercel: migrate during build is off by default (avoids P1002 advisory locks). Opt in:
# PRISMA_MIGRATE_ON_VERCEL=1
BLOB_READ_WRITE_TOKEN