# Are.na OAuth
ARENA_CLIENT_ID=
ARENA_CLIENT_SECRET=
ARENA_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App
# Include scheme (https:// or http://). Stripe checkout rejects bare hostnames.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=localhost:3000

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
# Snapshot (full payload) — billing logic in /api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Thin destination signing secret (if Stripe requires a second endpoint) — /api/billing/webhook-thin
STRIPE_WEBHOOK_THIN_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# One-time Price ID: price_… (legacy checkout when no valid monthly amount is sent)
# Monthly amounts from the pricing slider use Checkout subscription mode + price_data (no extra Price IDs).
STRIPE_SUPPORTER_PRICE_ID=

# Buttondown waitlist — newsletter slug from Settings → Embedding (same as in the form action URL),
# e.g. TinyFactories for https://buttondown.com/api/emails/embed-subscribe/TinyFactories
NEXT_PUBLIC_BUTTONDOWN_USER=

# Analytics (Umami v3)
# Website ID from your Umami site settings (UUID).
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Full URL to script.js — self-hosted v3: https://your-umami.example.com/script.js
# Server webhooks use the same host + /api/send (see src/lib/umami-server.ts).
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Cron (Vercel auto-sets this, or generate with: openssl rand -hex 32)
CRON_SECRET=

# Vercel API (for custom domain management)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Databases
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
BLOB_READ_WRITE_TOKEN