{
  "name": "tiny-garden",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/sync-feature-requests.mjs || node -e \"console.warn('[dev] feature-reviews sync failed; continuing with stale docs/feature-reviews.md')\"",
    "dev": "next dev --experimental-https",
    "build": "node scripts/run-build.cjs",
    "db:migrate": "node scripts/run-prisma.cjs migrate deploy",
    "db:baseline": "node scripts/run-prisma.cjs migrate resolve --applied 20260404_cli_foundation",
    "db:push": "node scripts/run-prisma.cjs db push",
    "postinstall": "node scripts/prisma-generate.cjs",
    "start": "next start",
    "lint": "next lint",
    "sync:feature-reviews": "node scripts/sync-feature-requests.mjs",
    "cli:build": "npm --prefix cli run build",
    "cli:start": "npm --prefix cli run start --"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@prisma/client": "^6.5.0",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "@vercel/blob": "^2.3.1",
    "handlebars": "^4.7.8",
    "lucide-react": "^1.7.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
