<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{channel.title}}</title>
  <link rel="stylesheet" href="style.css">
  <style>{{{site.custom_css}}}</style>
</head>
<body class="cs-body">
  <header class="cs-header">
    <h1 class="cs-title">{{channel.title}}</h1>
    {{#if channel.description}}<p class="cs-desc">{{channel.description}}</p>{{/if}}
  </header>
  <main class="cs-main">
    {{#each blocks}}
      {{> block}}
    {{/each}}
  </main>
</body>
</html>
