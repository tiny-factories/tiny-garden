<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{channel.title}}</title>
  <link rel="stylesheet" href="style.css">
  <style>{{{site.custom_css}}}</style>
</head>
<body class="sv-body-blog-home">

  <!-- Sticky nav bar — hidden by default, fades in on scroll -->
  <nav class="sv-blog-nav" id="sv-blog-nav">
    <div class="sv-blog-nav-inner">
      <a href="/" class="sv-blog-nav-logo" aria-label="Home"></a>
      <span class="sv-blog-nav-title">{{channel.title}}</span>
      <div class="sv-blog-nav-links">
        <a href="https://www.are.na/{{channel.user.slug}}">{{channel.user.name}}</a>
      </div>
    </div>
  </nav>

  <!-- Masthead -->
  <header class="sv-blog-intro" id="sv-blog-intro">
    <div class="sv-blog-intro-inner">
      <span class="sv-blog-intro-logo" aria-hidden="true"></span>
      <h1 class="sv-blog-intro-title">{{channel.title}}</h1>
      {{#if channel.description}}
        <p class="sv-blog-intro-description">{{channel.description}}</p>
      {{/if}}
      <p class="sv-blog-intro-meta">
        {{channel.length}} Entries &nbsp;/&nbsp; <a href="https://www.are.na/{{channel.user.slug}}">{{channel.user.name}}</a>
      </p>
    </div>
  </header>

  <!-- Articles -->
  <main class="sv-blog-articles">
    {{#each blocks}}
      {{> block}}
    {{/each}}
  </main>

  <!-- Footer -->
  <footer class="sv-blog-footer">
    <div class="sv-blog-footer-items">
      <a href="https://www.are.na/{{channel.user.slug}}">{{channel.user.name}} on Are.na</a>
      <a href="https://tiny.garden">Built with tiny.garden</a>
    </div>
  </footer>

  <!-- Scroll behaviour: show/hide sticky nav -->
  <script>
    (function () {
      var nav = document.getElementById('sv-blog-nav');
      var intro = document.getElementById('sv-blog-intro');
      if (!nav || !intro) return;

      function onScroll() {
        var introBottom = intro.getBoundingClientRect().bottom;
        if (introBottom <= 0) {
          nav.classList.add('is-visible');
        } else {
          nav.classList.remove('is-visible');
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
</body>
</html>
