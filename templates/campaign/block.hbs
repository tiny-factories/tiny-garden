<div class="sv-campaign-block block--{{type}}">

  {{#if (eq type "image")}}
    <figure class="sv-campaign-block-image">
      <img src="{{image.display}}" data-original="{{image.original}}" alt="{{title}}" loading="lazy">
    </figure>
    {{#if title}}
      <h2 class="sv-campaign-block-title">{{title}}</h2>
    {{/if}}
    {{#if description}}
      <p class="sv-campaign-block-description">{{description}}</p>
    {{/if}}
  {{/if}}

  {{#if (eq type "text")}}
    {{#if title}}
      <h2 class="sv-campaign-block-title">{{title}}</h2>
    {{/if}}
    <div class="sv-campaign-block-body">{{{content}}}</div>
  {{/if}}

  {{#if (eq type "link")}}
    <a href="{{link.url}}" class="sv-campaign-block-link" target="_blank" rel="noopener">
      {{#if link.thumbnail}}
        <figure class="sv-campaign-block-image">
          <img src="{{link.thumbnail}}" alt="" loading="lazy">
        </figure>
      {{/if}}
      <h2 class="sv-campaign-block-title">{{link.title}}</h2>
      {{#if link.description}}
        <p class="sv-campaign-block-description">{{link.description}}</p>
      {{/if}}
    </a>
  {{/if}}

  {{#if (eq type "media")}}
    {{#if title}}
      <h2 class="sv-campaign-block-title">{{title}}</h2>
    {{/if}}
    <div class="sv-campaign-block-embed">{{{embed.html}}}</div>
  {{/if}}

  {{#if (eq type "attachment")}}
    <a href="{{attachment.url}}" class="sv-campaign-block-attachment" download>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 1v10M4 8l4 4 4-4M2 14h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{{attachment.file_name}}</span>
    </a>
  {{/if}}

</div>
