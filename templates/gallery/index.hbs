<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{channel.title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <style>{{{site.custom_css}}}</style>
</head>
<body>
  <header class="gallery-site-header">
    <a href="/" class="gallery-site-title">{{channel.title}}</a>
    {{#if channel.user.name}}
      <a href="https://www.are.na/{{channel.user.slug}}" class="gallery-site-author">{{channel.user.name}}</a>
    {{/if}}
  </header>

  <main class="gallery-masonry">
    {{#each blocks}}
      {{> block}}
    {{/each}}
  </main>

  <dialog class="gallery-dialog" id="gallery-dialog" aria-label="Block details">
    <button type="button" class="gallery-dialog-close" aria-label="Close detail view">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </button>
    <div class="gallery-dialog-scroll">
      <div class="gallery-dialog-body" id="gallery-dialog-body"></div>
    </div>
  </dialog>

  <script>
    (function () {
      var dialog = document.getElementById("gallery-dialog");
      var body = document.getElementById("gallery-dialog-body");
      var closeBtn = dialog && dialog.querySelector(".gallery-dialog-close");
      if (!dialog || !body) return;

      document.querySelectorAll(".gallery-tile").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var item = btn.closest(".gallery-item");
          if (!item) return;
          var tpl = item.querySelector(".gallery-detail-template");
          if (!tpl) return;
          body.replaceChildren();
          body.appendChild(tpl.content.cloneNode(true));
          dialog.showModal();
          var focusTarget =
            body.querySelector(".gallery-detail-title") ||
            body.querySelector(".gallery-detail-figure img") ||
            body.querySelector(".gallery-detail-aside--solo") ||
            body.querySelector(".gallery-detail-embed") ||
            body.querySelector(".gallery-detail-link-placeholder") ||
            body.querySelector(".gallery-detail-aside a");
          if (focusTarget) {
            try {
              focusTarget.focus({ preventScroll: true });
            } catch (e) {}
          }
        });
      });

      if (closeBtn) {
        closeBtn.addEventListener("click", function () {
          dialog.close();
        });
      }

      dialog.addEventListener("click", function (e) {
        if (e.target === dialog) dialog.close();
      });

      dialog.addEventListener("close", function () {
        body.replaceChildren();
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && dialog.open) dialog.close();
      });
    })();
  </script>
</body>
</html>
