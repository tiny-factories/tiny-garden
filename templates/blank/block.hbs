<div class="block-item block-item-{{@index}} block-item--{{type}}">
  {{#if (eq type "image")}}
    <img src="{{image.display}}" alt="{{title}}" loading="lazy">
  {{/if}}

  {{#if (eq type "text")}}
    {{{content}}}
  {{/if}}

  {{#if (eq type "link")}}
    <a href="{{link.url}}" target="_blank" rel="noopener">{{link.title}}</a>
  {{/if}}

  {{#if (eq type "media")}}
    {{{embed.html}}}
  {{/if}}

  {{#if (eq type "attachment")}}
    {{#if image.display}}
      <img src="{{image.display}}" alt="{{attachment.alt_text}}" loading="lazy" style="max-width:100%">
    {{else}}
      {{#if (eq attachment.kind "video")}}
        <video controls preload="metadata" style="max-width:100%">
          <source src="{{attachment.url}}" type="{{attachment.content_type}}">
        </video>
      {{/if}}
      {{#if (eq attachment.kind "pdf")}}
        <iframe src="{{attachment.url}}" title="{{attachment.alt_text}}" loading="lazy" style="width:100%;height:420px;border:1px solid #ddd"></iframe>
      {{/if}}
    {{/if}}
    <a href="{{attachment.url}}" download>{{attachment.display_name}}</a>
    {{#if (eq attachment.kind "model")}}
      <p style="font-size:12px;opacity:0.8">3D model file ({{attachment.extension}}). Download to view in your preferred 3D tool.</p>
    {{/if}}
  {{/if}}
</div>
