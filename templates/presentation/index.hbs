<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{channel.title}}</title>
  <link rel="stylesheet" href="style.css">
  <style>{{{site.custom_css}}}</style>
</head>
<body>

  <div class="pres-deck" id="deck">

    <!-- Cover Slide -->
    <div class="pres-slide pres-slide-cover" data-index="0">
      <div class="pres-slide-inner pres-slide--cover">
        <h1 class="pres-cover-title">{{channel.title}}</h1>
        {{#if channel.description}}
          <div class="pres-cover-description">{{{channel.description}}}</div>
        {{/if}}
        <div class="pres-cover-meta">
          <a href="https://www.are.na/{{channel.user.slug}}">{{channel.user.name}}</a>
        </div>
      </div>
    </div>

    <!-- Block Slides -->
    {{#each blocks}}
      <div class="pres-slide" data-index="{{@index}}">
        {{> block}}
      </div>
    {{/each}}

  </div>

  <!-- Navigation Arrows -->
  <button class="pres-nav pres-nav-prev" id="prev" aria-label="Previous slide">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  <button class="pres-nav pres-nav-next" id="next" aria-label="Next slide">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>

  <!-- Slide Counter -->
  <div class="pres-counter" id="counter">
    <span id="current-num">1</span> / <span id="total-num">1</span>
  </div>

  <!-- Progress Bar -->
  <div class="pres-progress">
    <div class="pres-progress-bar" id="progress-bar"></div>
  </div>

  <script>
    (function () {
      var slides = document.querySelectorAll('.pres-slide');
      var prevBtn = document.getElementById('prev');
      var nextBtn = document.getElementById('next');
      var currentNum = document.getElementById('current-num');
      var totalNum = document.getElementById('total-num');
      var progressBar = document.getElementById('progress-bar');
      var total = slides.length;
      var current = 0;

      totalNum.textContent = total;

      function goTo(index) {
        if (total === 0) return;
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        for (var i = 0; i < slides.length; i++) {
          slides[i].classList.remove('active');
        }
        slides[index].classList.add('active');
        current = index;
        currentNum.textContent = current + 1;
        progressBar.style.width = ((current + 1) / total * 100) + '%';

        // Update nav visibility
        prevBtn.style.opacity = current === 0 ? '0.3' : '';
        nextBtn.style.opacity = current === total - 1 ? '0.3' : '';
      }

      // Button navigation
      prevBtn.addEventListener('click', function () { goTo(current - 1); });
      nextBtn.addEventListener('click', function () { goTo(current + 1); });

      // Keyboard navigation
      document.addEventListener('keydown', function (e) {
        switch (e.key) {
          case 'ArrowLeft':
          case 'ArrowUp':
            e.preventDefault();
            goTo(current - 1);
            break;
          case 'ArrowRight':
          case 'ArrowDown':
          case ' ':
            e.preventDefault();
            goTo(current + 1);
            break;
          case 'Home':
            e.preventDefault();
            goTo(0);
            break;
          case 'End':
            e.preventDefault();
            goTo(total - 1);
            break;
        }
      });

      // Click navigation (click left/right halves of screen)
      document.addEventListener('click', function (e) {
        // Ignore clicks on buttons, links, and interactive elements
        if (e.target.closest('a, button, .pres-nav, .pres-counter, .pres-embed')) return;
        var x = e.clientX;
        var w = window.innerWidth;
        if (x < w / 3) {
          goTo(current - 1);
        } else if (x > w * 2 / 3) {
          goTo(current + 1);
        }
      });

      // Touch swipe support
      var touchStartX = 0;
      document.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      document.addEventListener('touchend', function (e) {
        var diff = touchStartX - e.changedTouches[0].screenX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) goTo(current + 1);
          else goTo(current - 1);
        }
      }, { passive: true });

      // Initialize
      if (total > 0) goTo(0);
    })();
  </script>
</body>
</html>
