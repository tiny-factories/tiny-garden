<a class="fr-row block--{{type}} fr-row--stat-{{featureRequestStatusKey}}" href="{{featureRequestChildHref}}" data-fr-tags="{{featureRequestTagSlugsAttr}}">
  <div class="fr-row-main">
    {{#if (eq type "image")}}
      <span class="fr-cat">{{featureRequestCategoryLabel}}</span>
      <h2 class="fr-row-title">{{featureRequestRowTitle}}</h2>
      {{#if (featureRequestRowExcerpt)}}
        <p class="fr-row-desc">{{featureRequestRowExcerpt}}</p>
      {{/if}}
    {{/if}}

    {{#if (eq type "text")}}
      <span class="fr-cat">{{featureRequestCategoryLabel}}</span>
      {{#if title}}
        <h2 class="fr-row-title">{{featureRequestRowTitle}}</h2>
      {{/if}}
      {{#if (featureRequestRowExcerpt)}}
        <p class="fr-row-desc">{{featureRequestRowExcerpt}}</p>
      {{/if}}
    {{/if}}

    {{#if (eq type "link")}}
      <span class="fr-cat">{{featureRequestCategoryLabel}}</span>
      <h2 class="fr-row-title">{{featureRequestRowTitle}}</h2>
      {{#if (featureRequestRowExcerpt)}}
        <p class="fr-row-desc">{{featureRequestRowExcerpt}}</p>
      {{else}}
        {{#if description}}
          <p class="fr-row-desc">{{description}}</p>
        {{else}}
          {{#if link.description}}
            <p class="fr-row-desc">{{link.description}}</p>
          {{/if}}
        {{/if}}
      {{/if}}
    {{/if}}

    {{#if (eq type "media")}}
      <span class="fr-cat">{{featureRequestCategoryLabel}}</span>
      {{#if title}}
        <h2 class="fr-row-title">{{featureRequestRowTitle}}</h2>
      {{/if}}
      {{#if (featureRequestRowExcerpt)}}
        <p class="fr-row-desc">{{featureRequestRowExcerpt}}</p>
      {{/if}}
    {{/if}}

    {{#if (eq type "attachment")}}
      <span class="fr-cat">{{featureRequestCategoryLabel}}</span>
      <h2 class="fr-row-title">{{featureRequestRowTitle}}</h2>
      {{#if (featureRequestRowExcerpt)}}
        <p class="fr-row-desc">{{featureRequestRowExcerpt}}</p>
      {{/if}}
    {{/if}}
  </div>

  <div class="fr-row-status" aria-hidden="true">
    <span class="fr-status fr-status--{{featureRequestStatusKey}}"><span class="fr-status-dot"></span> {{featureRequestStatusLabel}}</span>
  </div>

  <div class="fr-row-date">
    <span class="fr-label">Submitted</span>
    <time datetime="{{created_at}}">{{formatDate created_at}}</time>
  </div>

  <div class="fr-row-vote">
    <span class="fr-vote-count">{{comment_count}}</span>
    <span class="fr-vote-btn" aria-hidden="true">↑</span>
  </div>
</a>
